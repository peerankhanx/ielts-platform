# Used by docker-compose.yml for the postgres container and to override
# defaults. The backend's own DB_USERNAME/DB_PASSWORD/DB_NAME in
# backend/.env should match these.
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=ielts_platform

CORS_ORIGIN=http://localhost:3000

# Baked into the frontend's client-side bundle at build time.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_MEDIA_BASE_URL=http://localhost:4000
