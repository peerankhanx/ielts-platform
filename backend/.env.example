NODE_ENV=development
PORT=4000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=ielts_platform

REDIS_HOST=localhost
REDIS_PORT=6379

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN_DAYS=30

CORS_ORIGIN=http://localhost:3000

# Optional: if set, the Writing module uses real Claude-based essay evaluation
# instead of the deterministic heuristic fallback. Get a key from
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: if set, the Subscriptions module uses real Stripe Checkout instead
# of the mock provider that settles payments immediately for local testing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: if SMTP_HOST is set, real emails are sent via SMTP (nodemailer)
# instead of being logged to the console. Verification/reset emails are
# queued through Redis/BullMQ either way.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Bandwise <no-reply@bandwise.dev>

# Optional: if set, the Speaking module transcribes recordings via OpenAI's
# Whisper API, which then unlocks real Lexical Resource / Grammatical Range
# scoring (via Claude) instead of leaving those two criteria unscored.
OPENAI_API_KEY=
